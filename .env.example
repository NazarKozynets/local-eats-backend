# LocalEats Backend - Environment Variables
# Copy this file to .env and fill in the values.

# Application
PORT=3000

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/localeats

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=local-eats

# E2E Tests (separate database, never the dev DB)
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5433/localeats_test
